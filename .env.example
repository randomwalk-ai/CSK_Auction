# Copy to .env in THIS folder (auction-data-pipeline/.env)
# Get a free key: https://console.groq.com/keys

GROQ_API_KEY=gsk_your_key_here

# Optional — require Groq verification before portrait download (default: off)
# When on, Groq must succeed OR auction-pool fallback applies if Groq API is down.
# PORTRAIT_REQUIRE_GROQ=1

# Optional — skip Groq for IPL 2026 auction-pool players (default: 1, avoids 429s)
# GROQ_SKIP_FOR_POOL=1

# Optional — pause after each Groq identity call when Groq runs (default: 1.0s)
# GROQ_IDENTITY_DELAY_S=1.0

# Optional — minimum spacing between Groq HTTP calls (default: 1.0s)
# GROQ_IDENTITY_MIN_INTERVAL_S=1.0

# Optional — Groq 429 retries before pool fallback (default: 4)
# GROQ_IDENTITY_MAX_RETRIES=4

# Portrait cache — keep off after a wipe until you run player_portraits.py rebuild
# PORTRAIT_WARM_ON_STARTUP=0
# PORTRAIT_FETCH_ON_REQUEST=0

# ESPN portraits — only for players WITHOUT an IPL face card (see seed_espn_portraits.py)
# ESPN_PORTRAIT_TRANSFORM=f_auto,t_ds_square_w_400,q_85
# ESPN_IPL_2026_SERIES_ID=1510719
# ESPN_HTTP_TRUST_ENV=0
# Paste browser cookies when httpx gets 403 (Chrome on espncricinfo.com → Console: document.cookie)
# ESPN_COOKIES=ci_geo_code=IN; ...
# Or save the same string to auction-data-pipeline/.espn_cookies (gitignored, auto-loaded)
# Headless Chromium for profile __NEXT_DATA__ when httpx is blocked (pip install playwright && playwright install chromium)
# ESPN_USE_PLAYWRIGHT=1
# ESPN_PLAYWRIGHT_AUTO=1
# ESPN_PLAYWRIGHT_CHANNEL=chrome
# ESPN_DEBUG=1
# Auto-use Playwright for profiles when .espn_cookies is set but httpx HTML has no __NEXT_DATA__
# PORTRAIT_SKIP_ESPN=1

# Portraits: IPL face card → ESPN → initials (Cricbuzz never used for images)
# IPL face cards (primary, URL only): scripts/seed_ipl_facecards.py
# ESPN fallback (no face card): python3 scripts/seed_espn_portraits.py --apply --delay 1.2

# Optional — log every pool fallback at WARNING (default: off, uses DEBUG)
# GROQ_IDENTITY_LOG_POOL_FALLBACK=1

# Optional — squad fetch model (default: llama-3.3-70b-versatile)
# GROQ_SQUAD_MODEL=llama-3.3-70b-versatile

# Optional — player metadata / valuation LLM
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_TEMPERATURE=0.05

# Optional — SQLite path
# DB_PATH=/full/path/to/auction_data.db
